{
  "name": "lwc-oss-snake-game",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "author": {
    "name": "Sebastiano Schwarz",
    "url": "https://github.com/svierk"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules __lwr_cache__ site",
    "dev": "lwr dev",
    "dev:compat": "lwr dev --mode compat",
    "build": "lwr build --clean",
    "build:prod-compat": "lwr build --clean --mode prod-compat",
    "lint": "eslint **/src/**/*.js",
    "lint:sonar": "eslint -f json -o eslint-report.json **/src/**/*.js",
    "prettier": "prettier --write \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\" --check",
    "prettier:verify": "prettier --list-different \"**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}\"",
    "postinstall": "husky",
    "precommit": "lint-staged",
    "start": "lwr start",
    "stage": "yarn build && yarn start",
    "stage:prod-compat": "yarn build:prod-compat && yarn start",
    "test:unit": "jest",
    "test:unit:watch": "jest --watch",
    "test:unit:coverage": "jest --coverage",
    "test:unit:debug": "jest --debug"
  },
  "dependencies": {
    "jest-environment-jsdom": "^30.4.1",
    "lwc": "9.3.4",
    "lwr": "0.23.6"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@babel/eslint-parser": "^8.0.1",
    "@lwc/eslint-plugin-lwc": "^3.5.0",
    "@lwc/jest-preset": "^19.6.1",
    "@sa11y/jest": "8.0.27",
    "@salesforce-ux/design-system": "2.30.4",
    "@salesforce/eslint-config-lwc": "^4.1.2",
    "@salesforce/eslint-plugin-lightning": "^2.0.0",
    "@salesforce/sfdx-lwc-jest": "7.1.2",
    "eslint": "^10",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest": "^29.15.2",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3"
  },
  "engines": {
    "node": "24.x.x",
    "npm": "11.x.x"
  },
  "volta": {
    "node": "24.x.x"
  },
  "lint-staged": {
    "**/*.{cls,cmp,component,css,html,js,json,md,page,trigger,xml,yaml,yml}": [
      "prettier --write --check"
    ],
    "**/*.{css,html,js}": [
      "eslint",
      "jest --passWithNoTests"
    ]
  },
  "packageManager": "yarn@4.14.1"
}
